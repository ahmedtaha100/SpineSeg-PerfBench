# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
*.egg-info/
.env
.env.*

# Runtime outputs regenerated by scripts
outputs/
runs/
checkpoints/
data/
datasets/
raw/
raw_data/
manuscript/
.wandb/
wandb/
artifacts/smoke_frozen/
artifacts/local_frozen/
artifacts/.gitkeep
artifacts/demo/
artifacts/demos/
logs/
tmp/
*.tmp
*.log

# Raw medical image formats are intentionally not redistributed
*.nii
*.nii.gz
*.mha
*.mhd
*.nrrd
*.dcm
*.dicom

# Model weights and checkpoints are generated locally, not committed.
*.pt
*.pth
*.ckpt
*.onnx
*.h5
*.hdf5
*.npy
*.npz

# The checked-in frozen bundle is explicitly allowed even though generic
# generated output and checkpoint paths are ignored elsewhere.
!artifacts/frozen/
!artifacts/frozen/**

# Notebook and OS noise
.ipynb_checkpoints/
.DS_Store
